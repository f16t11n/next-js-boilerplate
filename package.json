{
  "name": "next-js-boilerplate",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run check-breakpoints && next build --turbopack",
    "check-breakpoints": "node scripts/check-breakpoints.js",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "security": "npm audit",
    "ci": "npm run lint && npx tsc --noEmit && npm run test -- --coverage && npm run build && npm audit --production --audit-level=high || true",
    "smoke": "node scripts/smoke.js",
    "cd": "npm run build && echo 'Deployment placeholder – integrate real provider' && npm run smoke"
  },
  "dependencies": {
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "winston": "^3.17.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "playwright": "^1.55.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.4",
    "typescript": "^5"
  }
}
