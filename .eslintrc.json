{
  "extends": [
    "next/core-web-vitals",
    "plugin:security/recommended",
    "plugin:jsx-a11y/recommended",
    "plugin:prettier/recommended"
  ],
  "plugins": [
    "security",
    "prettier",
    "unused-imports",
    "jsx-a11y",
    "no-duplicate-imports",
    "no-duplicate-strings",
    "react",
    "import",
    "eslint-rules"
  ],
  "rules": {
    "eslint-rules/no-nonstandard-breakpoints": "error",
    "prettier/prettier": "error",
    "unused-imports/no-unused-imports": "error",
    "no-duplicate-imports/no-duplicate-imports": "error",
    "no-duplicate-strings/no-duplicate-strings": ["error", 3],
    "jsx-a11y/alt-text": ["error", {
      "elements": ["img", "object", "area", "input[type='image']", "svg", "button", "a", "label", "iframe", "audio", "video"],
      "img": [],
      "object": [],
      "area": [],
      "input[type='image']": [],
      "svg": [],
      "button": [],
      "a": [],
      "label": [],
      "iframe": [],
      "audio": [],
      "video": []
    }],
    "jsx-a11y/no-img-element": "error",
    "jsx-a11y/aria-role": "error",
    "jsx-a11y/aria-props": "error",
    "jsx-a11y/aria-proptypes": "error",
    "jsx-a11y/aria-unsupported-elements": "error",
    "jsx-a11y/role-has-required-aria-props": "error",
    "jsx-a11y/role-supports-aria-props": "error",
    "jsx-a11y/no-redundant-roles": "error",
    "jsx-a11y/no-noninteractive-element-interactions": "error",
    "jsx-a11y/no-static-element-interactions": "error",
    "jsx-a11y/no-autofocus": "error",
    "jsx-a11y/no-interactive-element-to-noninteractive-role": "error",
    "jsx-a11y/no-noninteractive-element-to-interactive-role": "error",
    "jsx-a11y/no-noninteractive-tabindex": "error",
    "jsx-a11y/tabindex-no-positive": "error",
    "react/jsx-no-duplicate-props": "error",
    "import/no-duplicates": "error",
    "security/detect-object-injection": "warn",
    "jsx-a11y/heading-has-content": "error",
    "jsx-a11y/html-has-lang": "error",
    "jsx-a11y/lang": "error",
    "jsx-a11y/media-has-caption": "error",
    "jsx-a11y/no-distracting-elements": "error",
    "jsx-a11y/prefer-tag-over-role": "error",
    "jsx-a11y/anchor-is-valid": ["error", { "aspects": ["invalidHref", "preferButton"] }],
    "jsx-a11y/label-has-associated-control": ["error", { "assert": "either" }],
    "jsx-a11y/no-access-key": "error"
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    ".next/",
    "dist/",
    "logs/"
  ],
  "overrides": [
    {
      "files": [
        "jest.setup.js",
        "jest.setup.ts",
        "setup*.js",
        "setup*.ts",
        "tests/**/*.js",
        "tests/**/*.ts",
        "**/*.test.js",
        "**/*.test.ts",
        "**/*.spec.js",
        "**/*.spec.ts"
      ],
      "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "module"
      },
      "rules": {
        "@typescript-eslint/no-require-imports": "off",
        "import/no-commonjs": "off"
      }
    }
  ]
}
